# =============================================================================
# Production environment for Render. DO NOT commit real secrets.
# Set these as Environment Variables in the Render dashboard (or via render.yaml).
# Generate APP_KEY locally with:  php artisan key:generate --show
# =============================================================================

APP_NAME="MAK Lost & Found"
APP_ENV=production
APP_KEY=                       # base64:....  (php artisan key:generate --show)
APP_DEBUG=false
APP_URL=https://YOUR-SERVICE.onrender.com

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ---- External MySQL (Aiven / Clever Cloud / PlanetScale-style host) ----
DB_CONNECTION=mysql
DB_HOST=your-mysql-host
DB_PORT=3306
DB_DATABASE=your-db-name
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
# If the provider requires TLS (Aiven does), download its CA cert, commit it to
# storage/certs/ca.pem, and set the path below. Leave blank if not required.
MYSQL_ATTR_SSL_CA=

# ---- Sessions / cache / queue ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# ---- Mail: Brevo (HTTP API — works on Render; SMTP ports are blocked there) ----
MAIL_MAILER=brevo
BREVO_API_KEY=xkeysib-your_api_key_here
# MAIL_FROM_ADDRESS must be a sender you have VERIFIED in Brevo
# (Brevo dashboard → Senders, Domains & Dedicated IPs → Senders → add + confirm).
# No domain required — verifying a single address lets you send to anyone.
MAIL_FROM_ADDRESS=your.verified@gmail.com
MAIL_FROM_NAME="MAK Lost & Found"

# ---- Cloudinary (persistent image storage) ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---- WhatsApp / SMS (keep as log unless you set up Twilio/Meta) ----
WHATSAPP_PROVIDER=log
